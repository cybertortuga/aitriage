# AITriage Configuration
# Place this file as aitriage.yaml in your project root.
# Docs: https://github.com/cybertortuga/aitriage

# ─── Legacy Failure Thresholds ────────────────────────────────────────────────
# Still supported when health_check is not set.
# Fail the scan (exit code 1) if ANY issue is found (default: only critical)
strict_mode: false

# Fail the scan if Health Check score drops below this value (0 = disabled)
fail_score: 70

# ─── Security Policy Gate ────────────────────────────────────────────────────
# This is the CI/CD answer to: can this project pass the security policy?
health_check:
  # baseline: compatible default; blocks active CRITICAL/HIGH by fail_on
  # standard: for sensitive/business apps; also enforces minimum_score 70
  # strict: for high-assurance systems; blocks any active finding
  profile: baseline
  fail_on: critical       # critical | any | never
  minimum_score: 70       # 0 = disabled
  max_critical: -1        # -1 = unlimited; 0 = block any active finding
  max_high: -1
  max_medium: -1
  block_sources:
    # - gitleaks
  block_classes:
    # - hardcoded-secret

# ─── Ignore Rules ─────────────────────────────────────────────────────────────
# Suppress specific rule IDs from results
ignore:
  rules:
    # - ENTR-SLOP-01   # Uncomment to ignore AI scaffolding residue warnings
    # - NEXT-LOGGING   # Uncomment to ignore missing logging rule

  # Suppress findings in specific paths (supports glob-style prefix matching)
  paths:
    # - tests/
    # - legacy/
    # - scripts/

# ─── Custom Rules ─────────────────────────────────────────────────────────────
# Add your own project-specific rules here
rules:
  # - id: CUSTOM-NO-CONSOLE-LOG
  #   name: "Direct console.log in production code"
  #   stack: nextjs
  #   extensions: [".ts", ".tsx"]
  #   target: code
  #   pattern: 'console\.log\('
  #   suggestion: "Use a structured logger instead of console.log in production."
  #   severity: "LOW"

# ─── LLM Integration (optional, for aitriage remedy --ai) ───────────────────
# llm:
#   provider: openai        # openai | anthropic | ollama
#   model: gpt-4o
#   api_key: ""             # use env var OPENAI_API_KEY instead of hardcoding!
#   timeout: 30
