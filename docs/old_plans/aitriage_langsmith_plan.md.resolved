## Фаза 1 — Scaffolding (день 1)

### 1.1 Создать `pyproject.toml`

```toml
[project]
name = "aitriage-labs"
version = "0.1.0"
description = "AITriage v2 — LangGraph + LangSmith"
requires-python = ">=3.11"
dependencies = [
    "langchain>=0.3",
    "langgraph>=0.2",
    "langchain-openai>=0.2",
    "langchain-anthropic>=0.2",
    "langsmith>=0.2",
    "click>=8.1",
    "pydantic>=2.0",
    "rich>=13.0",
]

[project.scripts]
aitriage-labs = "aitriage_labs.cli:main"

[tool.uv]
dev-dependencies = [
    "pytest>=8.0",
    "pytest-asyncio>=0.23",
]
```

### 1.2 `.env.example`

```bash
# LLM Provider (любой один)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith (обязательно)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=aitriage-labs
LANGSMITH_WORKSPACE_ID=a758f53f-8e41-44e5-8844-46b8079721ec

# Путь к Go-бинарю (опционально)
AITRIAGE_BINARY=aitriage
```

