  "faq": {
    "title": "FAQ & Documentation",
    "subtitle": "Learn how AITriage automates security orchestration, scanning, and remediation.",
    "howItWorks": {
      "title": "How AITriage Works",
      "content": "AITriage is a security analysis platform that orchestrates static application security testing (SAST), secret detection, and dependency scanning. It consolidates findings into a unified posture and uses the SecureCoder LLM engine to analyze vulnerabilities, generate remediation patches, and produce verification test cases."
    },
    "scanners": {
      "title": "Integrated Scanners",
      "subtitle": "Integrated security engines working concurrently to scan your project.",
      "semgrep": "SAST analysis for multiple languages, matching custom rules and patterns.",
      "trivy": "Scans package dependencies and container images for known vulnerabilities (CVEs).",
      "gitleaks": "Scans source files and Git history for hardcoded credentials, keys, and tokens.",
      "bandit": "Dedicated security linter targeting common vulnerabilities in Python code.",
      "securecoder": "AI agent layer providing automated patch generation and risk mitigation plans."
    },
    "features": {
      "title": "Key Functionality",
      "triage": "AI Triage Workspace: Generate precise prompts for vulnerability explanation, code fixes, threat modeling (STRIDE), and validation PoCs.",
      "topology": "Topology Mapping: Automatically build interactive visual graphs of infrastructure, databases, and message brokers.",
      "sbom": "Dependency Inventory: Manage Software Bill of Materials (SBOM) and check supply chain integrity.",
      "compliance": "Compliance Ledger: Generate signed compliance reports (SARIF, CycloneDX, SPDX, Executive PDF)."
    },
    "howToUse": {
      "title": "Platform Guide",
      "step1": "Configure Target: Input the path to your local project directory (e.g. /host/... or ~).",
      "step2": "Run Scan: Trigger a quick or full scan. The orchestrator triggers all active scanning engines.",
      "step3": "Analyze & Remediate: Select a finding, choose an AI template, and send the prompt to your Copilot or copy it to your IDE.",
      "step4": "Manage Posture: Mark findings as Triage, False Positive, or Accept Risk to keep the repository posture up-to-date."
    },
    "scoring": {
      "title": "Security Score Algorithm",
      "intro": "The Security Score represents the overall health of your codebase. It starts at a perfect 100 and decreases as unresolved issues are detected:",
      "critical": "Critical Severity: -25 points penalty. Automatically fails CI/CD build pipelines.",
      "high": "High Severity: -15 points penalty. Automatically fails CI/CD build pipelines.",
      "medium": "Medium Severity: -5 points penalty.",
      "low": "Low Severity: -1 point penalty.",
      "triagedNote": "Note: Findings manually triaged as 'Triage', 'False Positive', or 'Accepted Risk' are exempt from penalties and restore the score instantly."
    }
  },
