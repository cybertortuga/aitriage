# ==========================================
# CORE API KEYS (REQUIRED)
# ==========================================
# Provide the key for the LLM provider configured in your .aitriage.yaml.

# Gemini (Default) - https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI - https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic - https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==========================================
# ENTERPRISE SETTINGS (OPTIONAL)
# ==========================================
# JWT Secret for authenticating users. Change this in production!
JWT_SECRET=super-secret-development-key-change-in-prod
# Persistent SQLite database path
DB_PATH=/app/data/aitriage.db
# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# ==========================================
# LANGSMITH OBSERVABILITY (OPTIONAL)
# ==========================================
# Enable to trace LangGraph agent reasoning and LLM calls.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=aitriage

# ==========================================
# LANGGRAPH AGENT CONFIGURATION (OPTIONAL)
# ==========================================
# 1 = Agent asks for permission before writing fixes. 0 = Full Autopilot.
AGENT_HITL=1
